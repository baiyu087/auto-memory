{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/session-start-lessons.py\" 2>/dev/null || python \"${CLAUDE_PLUGIN_ROOT}/hooks/session-start-lessons.py\"",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/session-end-analyze.py\" 2>/dev/null || python \"${CLAUDE_PLUGIN_ROOT}/hooks/session-end-analyze.py\"",
            "timeout": 120
          }
        ]
      }
    ]
  }
}
